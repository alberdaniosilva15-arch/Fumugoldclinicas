# FumuGold V4 — Variáveis de ambiente
# Renomeia este ficheiro para .env e preenche os valores

# Supabase (obrigatório)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NVIDIA NIM (para a IA Assistente ARIA)
VITE_NVIDIA_KEY=nvapi-XXXXXXXXXX

# n8n Webhook (para o WhatsApp Monitor enviar respostas)
VITE_N8N_WEBHOOK=https://XXXX.ngrok-free.dev
VITE_NGROK_URL=https://XXXX.ngrok-free.dev

# Password de admin para operações sensíveis no painel
VITE_ADMIN_PASS=
